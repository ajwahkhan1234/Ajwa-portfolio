{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A portfolio project entry",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "The name of the project"
        },
        "description": {
          "type": "string",
          "description": "Short description of the project"
        },
        "fullDescription": {
          "type": "string",
          "description": "Detailed case study description"
        },
        "imageUrl": {
          "type": "string",
          "format": "uri",
          "description": "Link to the project thumbnail/main image"
        },
        "category": {
          "type": "string",
          "description": "Project category (e.g., Web Development, UI/UX)"
        },
        "technologies": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of technologies used"
        },
        "link": {
          "type": "string",
          "format": "uri",
          "description": "External link to the live project"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the project was added"
        }
      },
      "required": ["title", "description", "imageUrl", "category"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of portfolio projects"
    }
  }
}
