rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: projects
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required)
    //   - description: string (required)
    //   - fullDescription: string (optional)
    //   - imageUrl: string (required, URL)
    //   - category: string (required)
    //   - technologies: list (optional)
    //   - link: string (optional, URL)
    //   - year: string (optional)
    //   - client: string (optional)
    //   - role: string (optional)
    //   - problem: string (optional)
    //   - solution: string (optional)
    //   - features: list (optional)
    //   - results: list (optional)
    //   - gallery: list (optional)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
             (request.auth.token.email == "khanajwa950@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidProject(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.description is string && data.description.size() < 2000 &&
             data.imageUrl is string && data.imageUrl.matches("^https?://.*") &&
             data.category is string &&
             (data.createdAt is timestamp || data.updatedAt is timestamp);
    }

    match /projects/{projectId} {
      // Anyone can read projects to see the portfolio
      allow read: if true;
      
      // Only admin can create or update projects
      allow create: if isAdmin() && isValidProject(request.resource.data);
      allow update: if isAdmin() && isValidProject(request.resource.data);
      allow delete: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
